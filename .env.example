# Deepgram (STT)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Redis
REDIS_URL=redis://localhost:6379/0

# Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/voiceintake

# LLM (compatible with OpenAI SDK)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Session
SESSION_TTL_SECONDS=3600

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=voiceintake-ai

# Dev mode: use in-memory session store when Redis is unavailable
# DEV_MODE=true
